"""MCP server for PubMed, OMIM, and Orphanet searches."""

from __future__ import annotations

import json
import asyncio
from typing import Any

import httpx
from Bio import Entrez
from mcp.server import Server
from mcp.server.stdio import stdio_server
from mcp.types import Tool, TextContent

Entrez.email = "dxengine@example.com"

server = Server("pubmed-server")


def _entrez_search_pubmed(query: str, max_results: int = 5) -> list[dict]:
    """Search PubMed via Entrez and return article metadata."""
    handle = Entrez.esearch(db="pubmed", term=query, retmax=max_results)
    record = Entrez.read(handle)
    handle.close()

    id_list = record.get("IdList", [])
    if not id_list:
        return []

    handle = Entrez.efetch(db="pubmed", id=",".join(id_list), rettype="xml")
    articles = Entrez.read(handle)
    handle.close()

    results = []
    for article in articles.get("PubmedArticle", []):
        medline = article.get("MedlineCitation", {})
        pmid = str(medline.get("PMID", ""))
        article_data = medline.get("Article", {})

        title = str(article_data.get("ArticleTitle", ""))

        # Authors
        author_list = article_data.get("AuthorList", [])
        authors = []
        for author in author_list:
            last = author.get("LastName", "")
            first = author.get("ForeName", "")
            if last:
                authors.append(f"{last} {first}".strip())

        # Journal
        journal_info = article_data.get("Journal", {})
        journal = str(journal_info.get("Title", ""))

        # Year
        pub_date = journal_info.get("JournalIssue", {}).get("PubDate", {})
        year = str(pub_date.get("Year", ""))

        # Abstract
        abstract_parts = article_data.get("Abstract", {}).get("AbstractText", [])
        abstract = " ".join(str(part) for part in abstract_parts) if abstract_parts else ""

        results.append({
            "pmid": pmid,
            "title": title,
            "authors": authors,
            "journal": journal,
            "year": year,
            "abstract": abstract,
        })

    return results


def _entrez_get_article(pmid: str) -> dict:
    """Fetch a single PubMed article by PMID."""
    results = _entrez_search_pubmed(pmid, max_results=1)
    if results:
        return results[0]

    # Fallback: direct fetch
    handle = Entrez.efetch(db="pubmed", id=pmid, rettype="xml")
    articles = Entrez.read(handle)
    handle.close()

    for article in articles.get("PubmedArticle", []):
        medline = article.get("MedlineCitation", {})
        article_data = medline.get("Article", {})
        title = str(article_data.get("ArticleTitle", ""))
        abstract_parts = article_data.get("Abstract", {}).get("AbstractText", [])
        abstract = " ".join(str(part) for part in abstract_parts) if abstract_parts else ""

        return {
            "pmid": pmid,
            "title": title,
            "authors": [],
            "journal": "",
            "year": "",
            "abstract": abstract,
        }

    return {"pmid": pmid, "title": "", "authors": [], "journal": "", "year": "", "abstract": ""}


def _entrez_search_omim(query: str) -> list[dict]:
    """Search OMIM via NCBI Entrez."""
    handle = Entrez.esearch(db="omim", term=query, retmax=10)
    record = Entrez.read(handle)
    handle.close()

    id_list = record.get("IdList", [])
    if not id_list:
        return []

    handle = Entrez.esummary(db="omim", id=",".join(id_list))
    summaries = Entrez.read(handle)
    handle.close()

    results = []
    for summary in summaries:
        results.append({
            "uid": str(summary.get("Id", "")),
            "title": str(summary.get("Title", "")),
        })

    return results


async def _search_orphanet(query: str) -> list[dict]:
    """Search Orphanet via their API. Returns empty list on failure."""
    url = f"https://api.orphacode.org/EN/ClinicalEntity/ApproximateName/{query}"
    try:
        async with httpx.AsyncClient(timeout=10.0) as client:
            resp = await client.get(
                url,
                headers={"Accept": "application/json"},
            )
            if resp.status_code != 200:
                return []

            data = resp.json()
            results = []
            for entry in data if isinstance(data, list) else data.get("results", data.get("entities", [])):
                if isinstance(entry, dict):
                    results.append({
                        "orpha_code": str(entry.get("ORPHAcode", entry.get("orpha_code", ""))),
                        "name": str(entry.get("Preferred term", entry.get("name", entry.get("Name", "")))),
                        "description": str(entry.get("Definition", entry.get("description", ""))),
                    })
            return results
    except Exception:
        return []


@server.list_tools()
async def list_tools() -> list[Tool]:
    return [
        Tool(
            name="search_pubmed",
            description="Search PubMed for medical literature. Returns list of articles with PMID, title, authors, journal, year, and abstract.",
            inputSchema={
                "type": "object",
                "properties": {
                    "query": {"type": "string", "description": "PubMed search query"},
                    "max_results": {"type": "integer", "description": "Maximum number of results (default 5)", "default": 5},
                },
                "required": ["query"],
            },
        ),
        Tool(
            name="get_pubmed_article",
            description="Fetch full article metadata from PubMed by PMID.",
            inputSchema={
                "type": "object",
                "properties": {
                    "pmid": {"type": "string", "description": "PubMed ID"},
                },
                "required": ["pmid"],
            },
        ),
        Tool(
            name="search_omim",
            description="Search OMIM (Online Mendelian Inheritance in Man) for genetic disease information.",
            inputSchema={
                "type": "object",
                "properties": {
                    "query": {"type": "string", "description": "OMIM search query"},
                },
                "required": ["query"],
            },
        ),
        Tool(
            name="search_orphanet",
            description="Search Orphanet for rare disease information. Returns list of diseases with ORPHAcode, name, and description.",
            inputSchema={
                "type": "object",
                "properties": {
                    "query": {"type": "string", "description": "Orphanet search query (disease name)"},
                },
                "required": ["query"],
            },
        ),
        Tool(
            name="find_diagnostic_criteria",
            description="Search PubMed for diagnostic criteria for a specific disease.",
            inputSchema={
                "type": "object",
                "properties": {
                    "disease": {"type": "string", "description": "Disease name to find diagnostic criteria for"},
                },
                "required": ["disease"],
            },
        ),
    ]


@server.call_tool()
async def call_tool(name: str, arguments: dict) -> list[TextContent]:
    if name == "search_pubmed":
        query = arguments["query"]
        max_results = arguments.get("max_results", 5)
        result = _entrez_search_pubmed(query, max_results)
        return [TextContent(type="text", text=json.dumps(result, indent=2))]

    elif name == "get_pubmed_article":
        pmid = arguments["pmid"]
        result = _entrez_get_article(pmid)
        return [TextContent(type="text", text=json.dumps(result, indent=2))]

    elif name == "search_omim":
        query = arguments["query"]
        result = _entrez_search_omim(query)
        return [TextContent(type="text", text=json.dumps(result, indent=2))]

    elif name == "search_orphanet":
        query = arguments["query"]
        result = await _search_orphanet(query)
        return [TextContent(type="text", text=json.dumps(result, indent=2))]

    elif name == "find_diagnostic_criteria":
        disease = arguments["disease"]
        query = f"{disease} diagnostic criteria"
        result = _entrez_search_pubmed(query, max_results=5)
        return [TextContent(type="text", text=json.dumps(result, indent=2))]

    else:
        return [TextContent(type="text", text=json.dumps({"error": f"Unknown tool: {name}"}))]


async def main():
    async with stdio_server() as (read_stream, write_stream):
        await server.run(read_stream, write_stream)


if __name__ == "__main__":
    asyncio.run(main())
